# RetailPulse — environment variable template
# Copy to .env and fill in real values. Never commit .env to git.

# ── Application ───────────────────────────────────────────────────────────────
RETAILPULSE_SECRET=change-me-use-32-random-chars-min

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=retailpulse
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/retailpulse

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AI / LLM ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Email alerts ──────────────────────────────────────────────────────────────
ALERT_EMAIL_SENDER=your-sender@gmail.com
ALERT_EMAIL_PASSWORD=your-gmail-app-password
ALERT_EMAIL_RECEIVER=your-receiver@gmail.com
