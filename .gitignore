# Data - ignore large raw files; processed CSVs are tracked for Streamlit deployment
data/raw/*.csv
data/raw/*.xlsx
data/raw/*.xls
data/interim/*.csv

# retail_clean.csv is 72 MB — too large for git; all other processed CSVs are tracked
data/processed/retail_clean.csv

# Models - tracked for Streamlit deployment (all under 3 MB)
# models/*.pkl  ← intentionally NOT ignored

# Reports - figures tracked for Streamlit deployment; drift reports excluded
reports/drift/
reports/*.json
reports/load_test.html

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# ML checkpoints - binary training artifacts
checkpoints/

# MLflow - local tracking database and run artifacts
mlflow.db
mlruns/

# Runtime logs
logs/
